<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/navigation_home">

    <!-- Main Bottom Nav Destinations -->
    <fragment
        android:id="@+id/navigation_home"
        android:name="com.example.ksaturno.HomeFragment"
        android:label="Inicio"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/navigation_clients"
        android:name="com.example.ksaturno.clients.ClientsFragment"
        android:label="Clientes"
        tools:layout="@layout/fragment_clients" />

    <!-- Submenu and other primary destinations -->
    <fragment
        android:id="@+id/new_installation"
        android:name="com.example.ksaturno.instalaciones.InstalacionesFragment"
        android:label="Instalaciones"
        tools:layout="@layout/fragment_instalaciones">
        <action
            android:id="@+id/action_new_installation_to_step1"
            app:destination="@id/instalacionPaso1Fragment" />
    </fragment>

    <fragment
        android:id="@+id/active_services"
        android:name="com.example.ksaturno.servicios.ServiciosFragment"
        android:label="Servicios Activos"
        tools:layout="@layout/fragment_servicios" />

    <fragment android:id="@+id/units" android:name="com.example.ksaturno.units.UnitsFragment" />
    <fragment android:id="@+id/technicians" android:name="com.example.ksaturno.technicians.TechniciansFragment" />
    <fragment android:id="@+id/categories" android:name="com.example.ksaturno.categories.CategoriesFragment" />
    <fragment android:id="@+id/checklist_items" android:name="com.example.ksaturno.checklist.ChecklistFragment" />
    <dialog android:id="@+id/clientSearchFragment" android:name="com.example.ksaturno.clients.ClientSearchFragment" />

    <!-- Installation Wizard Flow -->
    <fragment
        android:id="@+id/instalacionPaso1Fragment"
        android:name="com.example.ksaturno.instalaciones.InstalacionFormFragment"
        android:label="Paso 1: Datos de Instalación">
        <action
            android:id="@+id/action_step1_to_step2"
            app:destination="@id/instalacionPaso2ChecklistFragment" />
    </fragment>

    <fragment
        android:id="@+id/instalacionPaso2ChecklistFragment"
        android:name="com.example.ksaturno.instalaciones.InstallationChecklistFragment"
        android:label="Paso 2: Checklist">
        <argument
            android:name="installationId"
            app:argType="integer" />
        <action
            android:id="@+id/action_step2_to_step3"
            app:destination="@id/instalacionPaso3EvidenceFragment" />
    </fragment>

    <fragment
        android:id="@+id/instalacionPaso3EvidenceFragment"
        android:name="com.example.ksaturno.instalaciones.InstallationEvidenceFragment"
        android:label="Paso 3: Evidencias">
        <argument
            android:name="installationId"
            app:argType="integer" />
    </fragment>

</navigation>