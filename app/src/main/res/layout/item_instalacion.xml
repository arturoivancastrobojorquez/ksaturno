<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tv_instalacion_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Instalacion ID: 1"
            android:textAppearance="@style/TextAppearance.AppCompat.Large" />

        <TextView
            android:id="@+id/tv_unidad_nombre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Unidad: Camioneta 1"/>

        <TextView
            android:id="@+id/tv_tecnico_nombre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tecnico: Juan Perez"/>

        <TextView
            android:id="@+id/tv_fecha_instalacion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fecha: 2024-01-15"/>

        <TextView
            android:id="@+id/tv_instalacion_estado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Estado: Completada"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>