<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_view_service_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tipo: Monitoreo GPS"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_view_service_unit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Unidad: Camión-01" />

            <TextView
                android:id="@+id/text_view_service_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estado: Activo" />

            <TextView
                android:id="@+id/text_view_service_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Monto: $250.00" />

        </LinearLayout>

        <ImageView
            android:id="@+id/image_view_edit_service"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_edit"
            android:contentDescription="Editar" />

        <ImageView
            android:id="@+id/image_view_delete_service"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_delete"
            android:contentDescription="Eliminar" />

    </LinearLayout>

</androidx.cardview.widget.CardView>