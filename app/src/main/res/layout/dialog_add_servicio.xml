<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cliente" />
        <TextView
            android:id="@+id/text_view_select_client_for_service"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:drawable/edit_text"
            android:clickable="true"
            android:drawableEnd="@drawable/ic_search"
            android:drawablePadding="8dp"
            android:focusable="true"
            android:gravity="center_vertical"
            android:hint="Seleccionar cliente..."
            android:padding="12dp"
            android:textSize="18sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Unidad (selecciona un cliente primero)" />
        <Spinner
            android:id="@+id/spinner_unit_for_service"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tipo de Servicio" />
        <Spinner
            android:id="@+id/spinner_service_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:layout_marginBottom="16dp" />

        <!-- Financial Info -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monto" />
        <EditText
            android:id="@+id/edit_text_service_amount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="$0.00"
            android:inputType="numberDecimal"
            android:minHeight="48dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Periodo de Pago" />
        <Spinner
            android:id="@+id/spinner_payment_period"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:layout_marginBottom="16dp" />

        <!-- Dates -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fecha de Inicio" />
        <EditText
            android:id="@+id/edit_text_service_start_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Seleccionar fecha..."
            android:focusable="false"
            android:clickable="true"
            android:minHeight="48dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fecha de Fin (Opcional)" />
        <EditText
            android:id="@+id/edit_text_service_end_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Seleccionar fecha..."
            android:focusable="false"
            android:clickable="true"
            android:minHeight="48dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fecha de Vencimiento (Opcional)" />
        <EditText
            android:id="@+id/edit_text_service_due_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Seleccionar fecha..."
            android:focusable="false"
            android:clickable="true"
            android:minHeight="48dp"
            android:layout_marginBottom="16dp" />

        <!-- Additional Details -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Estado" />
        <Spinner
            android:id="@+id/spinner_service_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tarjeta SIM" />
        <EditText
            android:id="@+id/edit_text_sim_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Número de SIM"
            android:minHeight="48dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Número de Periodos" />
        <EditText
            android:id="@+id/edit_text_num_periods"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ej: 12"
            android:inputType="number"
            android:minHeight="48dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Comentarios" />
        <EditText
            android:id="@+id/edit_text_service_comments"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Comentarios adicionales..."
            android:gravity="top"
            android:lines="3" />

    </LinearLayout>
</ScrollView>
